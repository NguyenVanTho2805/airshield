# AirShield Backend Environment Configuration
# ─────────────────────────────────────────────
# 1. Copy this file:  cp .env.example .env
# 2. Fill in ALL values marked REQUIRED
# 3. NEVER commit .env to git (already in .gitignore)
# 4. Run: python scripts/check_env.py  to validate

# ── Application ───────────────────────────────────────────────────────────────
APP_NAME=AirShield
APP_VERSION=1.0.0
DEBUG=true

# ── PostgreSQL credentials — REQUIRED (used by docker-compose AND backend) ────
# Change POSTGRES_PASSWORD to a strong random value, keep DATABASE_URL in sync
POSTGRES_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# ── Database (PostgreSQL + PostGIS) ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://airshield:REPLACE_WITH_STRONG_PASSWORD@localhost:5432/airshield_db

# ── Redis Cache ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Authentication (JWT) — REQUIRED ──────────────────────────────────────────
# Generate a secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET_KEY
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# ── IQAir API — REQUIRED (air quality data) ──────────────────────────────────
# Register free account → https://www.iqair.com/air-pollution-data-api
# Free tier: 10,000 calls/month
IQAIR_API_KEY=REPLACE_WITH_IQAIR_API_KEY
IQAIR_BASE_URL=https://api.airvisual.com/v2

# ── Google Gemini — REQUIRED (AI chatbot) ────────────────────────────────────
# Get API key → https://aistudio.google.com/app/apikey
# Free tier available
GEMINI_API_KEY=REPLACE_WITH_GEMINI_API_KEY
LLM_MODEL_NAME=gemini-2.5-flash

# ── Google Maps — OPTIONAL (clean route calculation) ─────────────────────────
# Enable Directions API → https://console.cloud.google.com/apis/library/directions-backend.googleapis.com
# Falls back to Haversine distance if not set
GOOGLE_MAPS_API_KEY=REPLACE_WITH_GOOGLE_MAPS_API_KEY
ROUTING_ALPHA=0.5

# ── Tuya IoT — OPTIONAL (smart home device control) ──────────────────────────
# Create project → https://iot.tuya.com/ → Cloud → Create Cloud Project
TUYA_CLIENT_ID=REPLACE_WITH_TUYA_CLIENT_ID
TUYA_CLIENT_SECRET=REPLACE_WITH_TUYA_CLIENT_SECRET

# ── Firebase FCM — OPTIONAL (push notifications) ─────────────────────────────
# Download JSON → Firebase Console → Project Settings → Service Accounts → Generate new private key
FIREBASE_CREDENTIALS_PATH=app/firebase_credentials.json

# ── CORS — OPTIONAL (restrict API access by origin) ──────────────────────────
# Development default allows localhost. In production set your real domains:
# CORS_ORIGINS=https://airshield.app,https://api.airshield.app
CORS_ORIGINS=http://localhost:3000,http://localhost:8080,http://localhost:8000

# ── Cache TTL — OPTIONAL (override default Redis TTL in seconds) ──────────────
# CACHE_TTL_AQI=300
# CACHE_TTL_FORECAST=3600
# CACHE_TTL_HISTORY=600

